DJANGO_SETTINGS_MODULE=api.settings
COMPOSE_PROJECT_NAME=intelvia
INTELVIA_IMAGE_TAG=v1.0.0-beta.5
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_PROVIDER_ALIAS_SECRET=replace-with-a-stable-provider-alias-secret
DJANGO_HOSTNAME=intelvia.app
DJANGO_DISABLE_LOGINS=False
DJANGO_LOGOUT_REDIRECT=https://intelvia.app
DJANGO_CAS_ROOT_PROXIED_AS=https://intelvia.app
PARQUET_CACHE_DIR=/app/parquet_cache

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=False
SENTRY_CAPTURE_HANDLED_HTTP_ERRORS=True

MARIADB_USER=intelvia
MARIADB_PASSWORD=replace-with-database-password
MARIADB_ROOT_PASSWORD=replace-with-root-database-password
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DATABASE=intelvia

SILICON_FLOW_API_KEY=
SILICON_FLOW_MODEL=
